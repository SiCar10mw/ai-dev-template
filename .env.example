# Shape only. Do not put real values in this file.
# Runtime code resolves these names through ai_dev_template.secrets.SecretProvider.

OPENAI_API_KEY=<secret-provider:openai-api-key>
ANTHROPIC_API_KEY=<secret-provider:anthropic-api-key>
GEMINI_API_KEY=<secret-provider:gemini-api-key>
MYTHOS_API_KEY=<secret-provider:mythos-api-key>
MACHINE_USER_TOKEN=<secret-provider:machine-user-token>
AZURE_TENANT_ID=<secret-provider:azure-tenant-id>
AZURE_CLIENT_ID=<secret-provider:azure-client-id>

# Prefer managed identity, OIDC, OAuth, or JWT over static secrets.
# If a local tool requires a secret during development, load it from an OS keyring or approved secret manager.
